{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ai_assets_hub;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "AiAssetsHub",
      "Audience": "AiAssetsHub.Frontend",
      "SigningKey": "replace-this-with-a-long-random-secret-for-production-2026",
      "ExpirationMinutes": 120
    }
  },
  "AllowedEmailDomains": {
    "Domains": [ "lg.com", "lg.com.br" ]
  },
  "AuthFlows": {
    "FrontendBaseUrl": "http://localhost:3000",
    "ExposeActionUrlsInApi": false,
    "EmailVerificationExpirationHours": 24,
    "PasswordResetExpirationMinutes": 30
  },
  "EmailDelivery": {
    "Provider": "AzureCommunicationServices",
    "AzureCommunicationServices": {
      "ConnectionString": "",
      "SenderAddress": "",
      "SenderDisplayName": "AI Assets Hub"
    }
  },
  "AdminEmails": [],
  "Seed": {
    "InitialContributor": {
      "Enabled": false,
      "FullName": "",
      "Email": "",
      "Password": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CorsOrigins": [ "http://localhost:3000" ],
  "AllowedHosts": "*"
}
