# ============================================
# AI Assets Hub - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=ai_assets_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- JWT Authentication ---
# Generate with: openssl rand -base64 64
JWT_SIGNING_KEY=CHANGE_ME_generate_a_long_random_secret_at_least_64_chars
JWT_EXPIRATION_MINUTES=120

# --- Application URLs ---
# The public URL where your app will be accessible
# Used for CORS and email links
CORS_ORIGIN=https://your-domain.com
FRONTEND_BASE_URL=https://your-domain.com

# The URL the frontend uses to call the backend API
# In Docker with nginx, this is the public URL (without /api suffix, the code adds it)
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com

# Port nginx listens on (mapped to host)
APP_PORT=80

# --- Email Domains ---
# Only users with these email domains can register
ALLOWED_DOMAIN_0=lg.com
ALLOWED_DOMAIN_1=lg.com.br

# --- Admin Users ---
# Emails that get Admin role automatically on login
ADMIN_EMAIL_0=marcelo.nascimento@lg.com.br

# --- Email Delivery (Azure Communication Services) ---
EMAIL_PROVIDER=AzureCommunicationServices
EMAIL_ACS_CONNECTION_STRING=endpoint=https://YOUR_RESOURCE.communication.azure.com/;accesskey=YOUR_KEY
EMAIL_ACS_SENDER=DoNotReply@YOUR_DOMAIN.azurecomm.net

# --- Initial Seed User (optional, for first deploy) ---
SEED_ENABLED=true
SEED_FULLNAME=Marcelo Nascimento
SEED_EMAIL=marcelo.nascimento@lg.com.br
SEED_PASSWORD=CHANGE_ME_initial_password
